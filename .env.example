# =============================================================================
# Environment Variables — Example / Template
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets.
# =============================================================================

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# TODO: Add your application-specific variables below

# --- Database ---
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# --- Authentication ---
# JWT_SECRET=your-secret-here
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret

# --- External Services ---
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG....
# S3_BUCKET=my-bucket
# AWS_REGION=us-east-1

# --- AI Tools (for local development) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- MCP Servers ---
# GITHUB_TOKEN=ghp_...
# BRAVE_API_KEY=...

# =============================================================================
# Autonomous Agent Configuration
# =============================================================================

# --- Jira Server (On-Premise) ---
# See docs/agent/jira-server-setup.md for detailed setup instructions.
#
# JIRA_URL=https://jira.yourcompany.com          # No trailing slash; include port if non-standard
# JIRA_EMAIL=ai-agent                            # LOGIN USERNAME (not email) for Jira Server
# JIRA_API_TOKEN=your-pat-or-password            # PAT (Jira 8.14+) or account password (older)
# JIRA_WEBHOOK_SECRET=your-32-char-random-secret # Shared secret for webhook validation
# JIRA_SERVER_IP=10.0.1.50                       # Jira Server IP for webhook receiver allowlist

# TLS (only if Jira uses internal CA or self-signed certificate)
# NODE_EXTRA_CA_CERTS=/path/to/internal-ca.crt

# HTTP Proxy (only if corporate proxy is required)
# HTTPS_PROXY=http://proxy.yourcompany.com:8080
# NO_PROXY=localhost,127.0.0.1,jira.yourcompany.com

# --- Jira Cloud (alternative to Jira Server) ---
# JIRA_URL=https://yourcompany.atlassian.net     # Cloud URL
# JIRA_EMAIL=developer@yourcompany.com           # Email address (Cloud uses email)
# JIRA_API_TOKEN=your-atlassian-api-token        # From https://id.atlassian.com/manage-profile/security/api-tokens

# --- Linear (alternative to Jira) ---
# LINEAR_API_KEY=lin_api_...

# --- Escalation Channels ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_TEAM_ID=T...

# --- Monitoring ---
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug

# --- Webhook Receiver ---
# WEBHOOK_PORT=3001                              # Port for Jira → Agent webhook delivery
