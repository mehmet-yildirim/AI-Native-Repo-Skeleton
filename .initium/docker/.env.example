# =============================================================================
# Initium Agent — Environment Variables
# =============================================================================
# Copy this file to docker/.env and fill in your values.
# Never commit the .env file — it contains secrets.
#
#   cp .initium/docker/.env.example .initium/docker/.env
# =============================================================================

# ── Target repository ─────────────────────────────────────────────────────────
# Full HTTPS clone URL of the repo the agent will work on.
# Include a token in the URL for private repos:
#   https://x-token:<GITHUB_TOKEN>@github.com/org/repo.git
GIT_REPO_URL=https://github.com/your-org/your-repo.git
GIT_BRANCH=main

# Optional — override git commit identity
# GIT_AUTHOR_NAME=Initium Agent
# GIT_AUTHOR_EMAIL=agent@noreply.local

# ── AI CLI ────────────────────────────────────────────────────────────────────
# Which CLI executes the agent workflows. Default: claude
#   claude  — Claude Code (uses .claude/commands/ slash commands natively)
#   cursor  — Cursor CLI  (reads command file content as a raw prompt;
#             does not support .claude/ slash commands directly)
# AGENT_CLI=claude

# ── AI Provider — choose ONE ──────────────────────────────────────────────────

# Option A: Anthropic (direct) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Option B: AWS Bedrock ────────────────────────────────────────────────────────
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=          # if using temporary credentials
# AWS_REGION=us-east-1

# Option C: Google Vertex AI ───────────────────────────────────────────────────
# CLAUDE_CODE_USE_VERTEX=1
# CLOUD_ML_REGION=us-east5
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# Mount your service account JSON via the volumes section in docker-compose.yml:
#   GOOGLE_APPLICATION_CREDENTIALS_PATH=/path/to/gcp-key.json

# ── JIRA ──────────────────────────────────────────────────────────────────────
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@your-company.com
JIRA_API_TOKEN=

# ── Git hosting auth (for PR creation) ───────────────────────────────────────
GITHUB_TOKEN=
# GITLAB_TOKEN=

# ── Linear (alternative to JIRA) ─────────────────────────────────────────────
# LINEAR_API_KEY=

# ── Cursor (passthrough — for projects using Cursor's BYOK inside the workspace)
# The agent runtime itself uses Claude Code CLI above.
# Set this if your workspace tooling or MCP servers authenticate via Cursor.
# CURSOR_API_KEY=

# ── Slack (escalation notifications) ─────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_TEAM_ID=T0XXXXXXX

# ── Webhook receiver (event-driven mode) ─────────────────────────────────────
# Used by the `webhook` service in docker-compose.yml.
# Jira Server will POST to http://<host>:<WEBHOOK_PORT><WEBHOOK_PATH>.
#
# Generate a secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JIRA_WEBHOOK_SECRET=
# WEBHOOK_PORT=3001
# WEBHOOK_PATH=/jira-webhook
# JIRA_SERVER_IP=192.168.1.10,192.168.1.11   # Optional IP allowlist

# ── Schedule ──────────────────────────────────────────────────────────────────
# Standard cron expression. Defaults to every 15 minutes if not set.
# GROOM_CRON=*/15 * * * *
