# =============================================================================
# GO
# =============================================================================
# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary (generated by go test -c)
*.test

# Output of go build
bin/
vendor/                 # Only ignore if not vendoring; remove this line if you use go mod vendor

# Go workspace file (keep go.work if you use workspaces)
# go.work.sum is usually committed; go.work can be committed or gitignored depending on team preference

# =============================================================================
# SWIFT / iOS (Xcode)
# =============================================================================
# Build artifacts
DerivedData/
*.ipa
*.dSYM/
*.dSYM.zip
*.app
build/

# Xcode user data
*.xcuserstate
xcuserdata/
.xcode.env.local

# Swift Package Manager
.build/
*.resolved              # Remove to commit Package.resolved (strongly recommended — keep this)
# NOTE: Package.resolved SHOULD be committed for reproducible builds
# Remove the line above if you keep Package.resolved (recommended)

# CocoaPods (if used instead of SPM)
Pods/
*.xcworkspace           # Only if generated by CocoaPods; keep if hand-authored
Podfile.lock            # KEEP this — commit Podfile.lock for reproducible builds

# Carthage
Carthage/Build/
Carthage/Checkouts/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

# Simulator
*.moved-aside
*.trim

# =============================================================================
# ANDROID / KOTLIN
# =============================================================================
# Build outputs
**/build/
!src/**/build/
*.apk
*.aab
*.ap_
*.dex
*.class
local.properties          # contains sdk.dir — machine-specific, never commit

# Signing (CRITICAL — never commit keystore files)
*.jks
*.keystore
keystore.properties
upload-keystore.jks
release.keystore

# Gradle
.gradle/
gradle-wrapper.jar        # Usually committed; remove this line to commit it
!gradle/wrapper/gradle-wrapper.jar
captures/
.externalNativeBuild/
.cxx/
*.hprof                   # Heap dumps

# Lint
lint/
*.lint.xml

# Android Studio profiler
*.trace

# =============================================================================
# FLUTTER / DART
# =============================================================================
# Dart tool
.dart_tool/
.packages
.pub-cache/
.pub/

# Build
build/
*.snapshot

# Flutter
.flutter-plugins
.flutter-plugins-dependencies
flutter_*.png

# NOTE: pubspec.lock SHOULD be committed for application projects
# for library packages, it is typically gitignored

# Generated files (usually kept for debugging; remove if committing)
*.g.dart                  # Remove this line to commit generated files
*.freezed.dart            # Remove this line to commit generated files

# iOS build artifacts (within Flutter project)
**/ios/Flutter/
**/ios/.symlinks/
**/android/.gradle/

# Coverage
coverage/

# =============================================================================
# REACT NATIVE / EXPO
# =============================================================================
# Expo
.expo/
.expo-shared/
dist/                     # Expo web build
web-build/

# React Native
ios/build/
android/build/
android/app/build/
android/.gradle/
*.jsbundle
*.map                     # Source maps (keep for error tracking — remove to exclude)

# Metro bundler
.metro-health-check-result

# Watchman
.watchmanconfig           # Keep if committed for team consistency

# Expo EAS
.eas/

# =============================================================================
# DATABASES
# =============================================================================
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.mdb
*.ldf
*.mdf
dump.sql
dump.rdb
*.rdb                     # Redis dump
data/                     # Local DB data directories

# =============================================================================
# DOCKER
# =============================================================================
.docker/
docker-compose.override.yml   # Local overrides — usually not committed

# =============================================================================
# TERRAFORM / INFRASTRUCTURE
# =============================================================================
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars                  # Variable files with secrets — never commit
!*.tfvars.example         # Example files are OK to commit
.terraform.lock.hcl       # Keep this — commit provider lock file

# =============================================================================
# KUBERNETES / HELM
# =============================================================================
*.kubeconfig
kubeconfig
secrets.yaml
*-secret.yaml
*-secrets.yaml
!*-secret.example.yaml

# =============================================================================
# LOGS & TEMP FILES
# =============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*
*.pid
*.seed
*.pid.lock
*.temp
*.tmp
tmp/
temp/
.cache/

# =============================================================================
# TEST & COVERAGE OUTPUTS
# =============================================================================
coverage/
.nyc_output/
test-results/
junit*.xml
*.lcov
*.cover
reports/

# =============================================================================
# AI TOOL — LOCAL OVERRIDES & RUNTIME STATE
# =============================================================================
# Keep shared AI config; ignore local overrides and runtime files
.continue/.cache/
.cursor/.cache/
.claude/settings.local.json

# Autonomous agent runtime (generated at runtime — commit skeleton.json only)
.agent/state/
.agent/audit/
.agent/escalations/
.agent/outputs/
.agent/STOP
.agent/webhook-receiver.mjs    # Deployed copy — track .agent-templates/ instead
