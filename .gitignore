# =============================================================================
# .gitignore — Initium
# Covers: Java, .NET/C#, Python, TypeScript/JavaScript, Go, Swift/iOS,
#         Android/Kotlin, Flutter/Dart, React Native/Expo, and shared tooling.
# =============================================================================

# =============================================================================
# SECRETS & CREDENTIALS — never commit these
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
secrets/
credentials/
service-account*.json
*-service-account.json
google-services.json         # Android Firebase — per-environment, not committed
GoogleService-Info.plist     # iOS Firebase — per-environment, not committed
keystore.properties          # Android signing keystore config

# =============================================================================
# OS-GENERATED FILES
# =============================================================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory

