root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 2

[*.{ts,tsx,js,jsx,json,yaml,yml,css,scss,html,mdc,md}]
indent_size = 2

[*.{py}]
indent_size = 4

[*.{go}]
indent_style = tab
indent_size = 4

[*.{rs}]
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
